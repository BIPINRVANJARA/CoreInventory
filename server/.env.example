# ===========================================
# Vyntro - Environment Configuration
# Copy this file to .env and fill in your values
# ===========================================

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=core_inventory

# JWT Authentication
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=7d

# Server
PORT=5000

# SMTP (Email OTP) — Use Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
EMAIL_FROM="Vyntro Security" <your_email@gmail.com>
